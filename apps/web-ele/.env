# 应用标题
VITE_APP_TITLE=Yumie 管理後台

# 应用命名空间，用于缓存、store等功能的前缀，确保隔离
VITE_APP_NAMESPACE=yumie-backoffice

# 对store进行加密的密钥，在将store持久化到localStorage时会使用该密钥进行加密
VITE_APP_STORE_SECURE_KEY=yumie-backoffice-replace-me

# 顧客端訂房站 base URL（異業合作 QR Code 編碼用）。預設正式站；
# 若 staging/dev 要指向測試前端，於對應 .env.* 覆寫此值。
VITE_GLOB_BOOKING_BASE_URL=https://yumie.flybooking.io
